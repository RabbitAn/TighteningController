<Window x:Class="TighteningController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TighteningController"
        Title="拧紧控制器 - Open Protocol"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolConverter x:Key="InvBool"/>
        <local:BoolToColorConverter x:Key="BoolToColor"/>
        <local:ResultToColorConverter x:Key="ResultColor"/>
        <local:AlarmActiveConverter x:Key="AlarmActive"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#E74C3C"/>
        </Style>
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#27AE60"/>
        </Style>
        <Style x:Key="WarningBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#F39C12"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="StatusBox" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部连接栏 -->
        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="12" Margin="0,0,0,8"
                BorderBrush="#BDC3C7" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="IP:" Style="{StaticResource LabelStyle}"/>
                <TextBox Grid.Column="1" Text="{Binding IpAddress}" Width="130" Style="{StaticResource InputBox}"
                         IsEnabled="{Binding CanConnect}"/>
                <TextBlock Grid.Column="2" Text="端口:" Style="{StaticResource LabelStyle}" Margin="8,0,4,0"/>
                <TextBox Grid.Column="3" Text="{Binding Port}" Width="60" Style="{StaticResource InputBox}"
                         IsEnabled="{Binding CanConnect}"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                    <CheckBox Content="自动重连" IsChecked="{Binding AutoReconnect}" Margin="0,0,4,0"
                              IsEnabled="{Binding CanConnect}"/>
                </StackPanel>

                <StackPanel Grid.Column="6" Orientation="Horizontal">
                    <Button Content="连接" Command="{Binding ConnectCommand}" Style="{StaticResource SuccessBtn}"/>
                    <Button Content="断开" Command="{Binding DisconnectCommand}" Style="{StaticResource DangerBtn}"/>
                </StackPanel>

                <Border Grid.Column="7" Style="{StaticResource StatusBox}" Margin="8,0,0,0"
                        Background="{Binding IsConnected, Converter={StaticResource BoolToColor}}">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧控制面板 -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,4,0">
                <StackPanel>

                    <!-- VIN设置 -->
                    <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                            BorderBrush="#BDC3C7" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="VIN码设置" Style="{StaticResource SectionHeader}"/>
                            <TextBox Text="{Binding VinNumber}" Style="{StaticResource InputBox}"
                                     Margin="0,0,0,4" MaxLength="25"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="发送VIN" Command="{Binding SendVinCommand}" Style="{StaticResource ActionBtn}"/>
                                <Button Content="取消订阅" Command="{Binding UnsubscribeVinCommand}" Style="{StaticResource WarningBtn}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 参数集选择 -->
                    <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                            BorderBrush="#BDC3C7" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="参数集(PSET)" Style="{StaticResource SectionHeader}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="PSET ID:" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding PsetId}" Width="60" Style="{StaticResource InputBox}"/>
                            </StackPanel>
                            <Button Content="选择PSET" Command="{Binding SelectPsetCommand}" Style="{StaticResource ActionBtn}"/>
                        </StackPanel>
                    </Border>

                    <!-- 批次控制 -->
                    <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                            BorderBrush="#BDC3C7" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="批次控制" Style="{StaticResource SectionHeader}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="批次大小:" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding BatchSize}" Width="60" Style="{StaticResource InputBox}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="当前计数:" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding BatchCount}" FontWeight="Bold" FontSize="16" Foreground="#2C3E50"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="设定批次" Command="{Binding SetBatchCommand}" Style="{StaticResource ActionBtn}"/>
                                <Button Content="批次清零" Command="{Binding ResetBatchCommand}" Style="{StaticResource WarningBtn}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 拧紧控制 -->
                    <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                            BorderBrush="#BDC3C7" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="拧紧控制" Style="{StaticResource SectionHeader}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Button Content="开始拧紧" Command="{Binding StartTighteningCommand}" Style="{StaticResource SuccessBtn}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="使能工具" Command="{Binding EnableToolCommand}" Style="{StaticResource SuccessBtn}"/>
                                <Button Content="禁用工具" Command="{Binding DisableToolCommand}" Style="{StaticResource DangerBtn}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 订阅管理 -->
                    <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                            BorderBrush="#BDC3C7" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="订阅管理" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="拧紧结果订阅" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="Rev:" Style="{StaticResource LabelStyle}"/>
                                <ComboBox SelectedIndex="0" Width="60" Margin="2"
                                          SelectedValue="{Binding SelectedRevision}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="Rev1" Tag="1"/>
                                    <ComboBoxItem Content="Rev2" Tag="2"/>
                                    <ComboBoxItem Content="Rev3" Tag="3"/>
                                    <ComboBoxItem Content="Rev4" Tag="4"/>
                                    <ComboBoxItem Content="Rev5" Tag="5"/>
                                    <ComboBoxItem Content="Rev6" Tag="6"/>
                                    <ComboBoxItem Content="Rev7" Tag="7"/>
                                    <ComboBoxItem Content="Rev8" Tag="8"/>
                                    <ComboBoxItem Content="Rev9" Tag="9"/>
                                    <ComboBoxItem Content="Rev10" Tag="10"/>
                                    <ComboBoxItem Content="Rev11" Tag="11"/>
                                    <ComboBoxItem Content="Rev12" Tag="12"/>
                                    <ComboBoxItem Content="Rev13" Tag="13"/>
                                    <ComboBoxItem Content="Rev14" Tag="14"/>
                                    <ComboBoxItem Content="Rev15" Tag="15"/>
                                    <ComboBoxItem Content="Rev999" Tag="999"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="订阅" Command="{Binding SubscribeTighteningCommand}" Style="{StaticResource SuccessBtn}"/>
                                <Button Content="取消" Command="{Binding UnsubscribeTighteningCommand}" Style="{StaticResource WarningBtn}"/>
                                <Ellipse Width="10" Height="10" Margin="6,0,0,0" VerticalAlignment="Center"
                                         Fill="{Binding IsSubscribedTightening, Converter={StaticResource BoolToColor}}"/>
                            </StackPanel>

                            <TextBlock Text="报警订阅" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="订阅" Command="{Binding SubscribeAlarmCommand}" Style="{StaticResource SuccessBtn}"/>
                                <Button Content="取消" Command="{Binding UnsubscribeAlarmCommand}" Style="{StaticResource WarningBtn}"/>
                                <Ellipse Width="10" Height="10" Margin="6,0,0,0" VerticalAlignment="Center"
                                         Fill="{Binding IsSubscribedAlarm, Converter={StaticResource BoolToColor}}"/>
                            </StackPanel>

                            <TextBlock Text="自动/手动模式订阅" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="订阅" Command="{Binding SubscribeAutoManualCommand}" Style="{StaticResource SuccessBtn}"/>
                                <Button Content="取消" Command="{Binding UnsubscribeAutoManualCommand}" Style="{StaticResource WarningBtn}"/>
                                <Ellipse Width="10" Height="10" Margin="6,0,0,0" VerticalAlignment="Center"
                                         Fill="{Binding IsSubscribedAutoManual, Converter={StaticResource BoolToColor}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 报警处理 -->
                    <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                            BorderBrush="{Binding IsAlarmActive, Converter={StaticResource AlarmActive}}" BorderThickness="2">
                        <StackPanel>
                            <TextBlock Text="报警状态" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="{Binding AlarmInfo}" FontSize="12" Margin="0,0,0,4"
                                       Foreground="{Binding IsAlarmActive, Converter={StaticResource AlarmActive}}"/>
                            <Button Content="远程确认报警" Command="{Binding AcknowledgeAlarmCommand}" Style="{StaticResource DangerBtn}"/>
                        </StackPanel>
                    </Border>

                    <!-- 数据请求 -->
                    <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                            BorderBrush="#BDC3C7" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="数据请求" Style="{StaticResource SectionHeader}"/>
                            <Button Content="请求工具数据" Command="{Binding RequestToolDataCommand}"
                                    Style="{StaticResource ActionBtn}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="结果ID:" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding RequestedTighteningId}" Width="80" Style="{StaticResource InputBox}"/>
                            </StackPanel>
                            <Button Content="请求历史结果" Command="{Binding RequestOldTighteningResultCommand}"
                                    Style="{StaticResource ActionBtn}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="离线结果:" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding OfflineResultCount}" FontWeight="Bold" FontSize="14" Foreground="#E67E22"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧数据展示区 -->
            <Grid Grid.Column="1" Margin="4,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>

                <!-- 最新拧紧结果卡片 -->
                <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,6"
                        BorderBrush="#BDC3C7" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="扭矩" FontSize="11" Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding LastTorque}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="角度" FontSize="11" Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding LastAngle}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="4">
                            <TextBlock Text="结果" FontSize="11" Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding LastResult}" FontSize="22" FontWeight="Bold"
                                       Foreground="{Binding LastResult, Converter={StaticResource ResultColor}}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="4">
                            <TextBlock Text="策略" FontSize="11" Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding LastStrategy}" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Margin="4">
                            <TextBlock Text="VIN" FontSize="11" Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding LastVin}" FontSize="12" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                        </StackPanel>
                        <StackPanel Grid.Column="5" Margin="4">
                            <TextBlock Text="拧紧ID" FontSize="11" Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding LastTighteningId}" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="4" Orientation="Horizontal">
                            <TextBlock Text="扭矩限值: " FontSize="11" Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding LastTorqueLimits}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="3" Margin="4" Orientation="Horizontal">
                            <TextBlock Text="角度限值: " FontSize="11" Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding LastAngleLimits}" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 状态信息栏 -->
                <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                        BorderBrush="#BDC3C7" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <TextBlock Text="模式:" Style="{StaticResource LabelStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ModeInfo}" Style="{StaticResource LabelStyle}"
                                       Foreground="{Binding IsManualMode, Converter={StaticResource BoolToColor}}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <TextBlock Text="报警:" Style="{StaticResource LabelStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding AlarmInfo}" Style="{StaticResource LabelStyle}"
                                       Foreground="{Binding IsAlarmActive, Converter={StaticResource AlarmActive}}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <TextBlock Text="工具:" Style="{StaticResource LabelStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ToolInfo}" Style="{StaticResource LabelStyle}"
                                       TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 拧紧结果列表 -->
                <Border Grid.Row="2" Background="White" CornerRadius="6" Margin="0,0,0,6"
                        BorderBrush="#BDC3C7" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="拧紧结果历史" Style="{StaticResource SectionHeader}"
                                   Margin="10,8,0,0"/>
                        <DataGrid ItemsSource="{Binding TighteningResults}" AutoGenerateColumns="False"
                                  IsReadOnly="True" AlternatingRowBackground="#F8F9FA"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  BorderThickness="0" Margin="4" FontSize="11"
                                  SelectedIndex="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding TighteningId}" Width="60"/>
                                <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="70"/>
                                <DataGridTextColumn Header="VIN" Binding="{Binding VinNumber}" Width="100"/>
                                <DataGridTextColumn Header="扭矩" Binding="{Binding Torque, StringFormat=F2}" Width="70"/>
                                <DataGridTextColumn Header="单位" Binding="{Binding TorqueUnit}" Width="40"/>
                                <DataGridTextColumn Header="角度" Binding="{Binding Angle}" Width="55"/>
                                <DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="45"/>
                                <DataGridTextColumn Header="PSET" Binding="{Binding ParameterSetId}" Width="45"/>
                                <DataGridTextColumn Header="Job" Binding="{Binding JobId}" Width="40"/>
                                <DataGridTextColumn Header="批次" Binding="{Binding BatchCounter}" Width="45"/>
                                <DataGridTextColumn Header="策略" Binding="{Binding Strategy}" Width="70"/>
                                <DataGridTextColumn Header="扭矩下限" Binding="{Binding TorqueMin, StringFormat=F2}" Width="70"/>
                                <DataGridTextColumn Header="扭矩上限" Binding="{Binding TorqueMax, StringFormat=F2}" Width="70"/>
                                <DataGridTextColumn Header="角度下限" Binding="{Binding AngleMin}" Width="60"/>
                                <DataGridTextColumn Header="角度上限" Binding="{Binding AngleMax}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- 日志区域 -->
                <Border Grid.Row="3" Background="#1E1E1E" CornerRadius="6"
                        BorderBrush="#BDC3C7" BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,4,0,0">
                            <TextBlock Text="通信日志" Foreground="#569CD6" FontWeight="Bold" FontSize="12" Margin="0,0,8,0"/>
                            <Button Content="清空" Command="{Binding ClearLogCommand}" Padding="6,2"
                                    Background="#333333" Foreground="#CCCCCC" BorderThickness="0" FontSize="10"
                                    Cursor="Hand"/>
                        </StackPanel>
                        <TextBox Text="{Binding LogMessages, Mode=OneWay}" IsReadOnly="True"
                                 Foreground="#D4D4D4" Background="Transparent" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" Margin="8,4,8,8"
                                 IsTabStop="False" Focusable="False"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="#2C3E50" CornerRadius="0,0,6,6" Padding="8,4" Margin="0,4,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center"
                         Fill="{Binding IsConnected, Converter={StaticResource BoolToColor}}"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="White" Margin="6,0,0,0"
                           VerticalAlignment="Center" FontSize="11"/>
                <TextBlock Grid.Column="3" Foreground="#95A5A6" FontSize="10" VerticalAlignment="Center">
                    <Run Text="拧紧结果:"/>
                    <Run Text="{Binding TighteningResults.Count, Mode=OneWay}" Foreground="#3498DB"/>
                    <Run Text=" | 报警:"/>
                    <Run Text="{Binding AlarmHistory.Count, Mode=OneWay}" Foreground="#E74C3C"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
